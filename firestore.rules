rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------
    // Helper Functions
    // ------------------------------------

    // Check if the request is from an authenticated user
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is an HR user (has a document in hr_users collection)
    function isHRUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/hr_users/$(request.auth.uid));
    }

    // ------------------------------------
    // Candidates Collection Rules
    // ------------------------------------
    match /candidates/{candidateId} {
      // Public read-only access (get by unique candidate ID) for candidate-portal status display
      allow get: if true;

      // Strict authenticated access for listing all candidates
      allow list: if isHRUser();

      // Write parameters (create, update, delete) restricted to HR or isolated candidate-matching actions
      allow create: if isHRUser() || (isAuthenticated() && request.auth.uid == candidateId);
      allow update, delete: if isHRUser() || (isAuthenticated() && request.auth.uid == candidateId);
    }

    // ------------------------------------
    // Assessments Collection Rules
    // ------------------------------------
    match /assessments/{token} {
      // Candidates can retrieve details of their specific assessment by token
      allow get: if true;

      // Candidates submit answers (which update the assessment document), server validates during update
      allow update: if true;

      // Strict authenticated authorization for writing or listing assessments
      allow list, create, delete: if isHRUser();
    }

    // ------------------------------------
    // Jobs Collection Rules
    // ------------------------------------
    match /jobs/{jobId} {
      // Anyone can read active job positions for the apply portal job selector
      allow read: if true;

      // Only authenticated HR users can write jobs
      allow write: if isHRUser();
    }

    // ------------------------------------
    // HR Users Profile Collection Rules
    // ------------------------------------
    match /hr_users/{uid} {
      // Strict dynamic user isolation: authenticated user can only access/manage their own profile
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // ------------------------------------
    // Internal Error Logs Rules
    // ------------------------------------
    match /errors/{errorId} {
      // Only authenticated HR users can inspect error logs
      allow read: if isHRUser();

      // Writes blocked for standard clients (reserved for cloud server SDK)
      allow write: if false;
    }
  }
}
