# ============================================
# HR Recruitment Funnel — Environment Variables
# ============================================

# --- Firebase Admin SDK ---
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# --- Frontend Firebase Config ---
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- SendGrid Email ---
SENDGRID_API_KEY=SG.your-key-here
SENDGRID_FROM_EMAIL=hr@yourcompany.com

# --- Google Calendar API ---
GOOGLE_CALENDAR_CREDENTIALS_PATH=./calendar_credentials.json
GOOGLE_CALENDAR_ID=primary

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- Application URLs ---
FRONTEND_URL=http://localhost:5173
ASSESSMENT_BASE_URL=http://localhost:5173/assessment

# --- JWT Settings ---
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
ASSESSMENT_TOKEN_EXPIRY_HOURS=72

# --- Scoring Defaults ---
CRITICAL_SKILL_PENALTY=15.0
DEFAULT_AUTO_REJECT_DEADLINE_HOURS=72
