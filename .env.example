# ============================================================
# RecruitFlow — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ============================================================

# --- Firebase Admin SDK (Backend) ---
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FORCE_MOCK_MODE=false


# --- Frontend Firebase Config (get from Firebase Console → Project Settings) ---
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- Google Gemini AI (get a free key at https://aistudio.google.com/) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Gmail SMTP (use a Gmail App Password, not your real password) ---
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password

# --- Google Calendar API (optional) ---
GOOGLE_CALENDAR_CREDENTIALS_PATH=./calendar_credentials.json
GOOGLE_CALENDAR_ID=primary

# --- Frontend API (Vite) ---
# Dev: point at local FastAPI. Prod: use /api for same-origin deploy.
VITE_API_URL=http://127.0.0.1:8001/api
# Set true to force client-side mock Firebase (must match backend FORCE_MOCK_MODE)
VITE_FORCE_MOCK_MODE=false

# --- Application URLs ---
# For local development:
FRONTEND_URL=http://localhost:5173
ASSESSMENT_BASE_URL=http://localhost:5173/assessment
# For production, replace with your deployed domain:
# FRONTEND_URL=https://your-project-id.web.app
# ASSESSMENT_BASE_URL=https://your-backend-domain.com/assessment

# --- JWT Settings ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-secure-random-string-in-production
JWT_ALGORITHM=HS256
ASSESSMENT_TOKEN_EXPIRY_HOURS=72

# --- Scoring Defaults ---
CRITICAL_SKILL_PENALTY=15.0
DEFAULT_AUTO_REJECT_DEADLINE_HOURS=72
