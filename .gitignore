# ============================================================
# RecruitFlow — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# --- Virtual environments & local Python runtimes ---
venv/
.venv/
env/
python312/
*.pth

# --- Environment & Secrets (NEVER commit these) ---
.env
.env.local
.env.*.local

# --- Firebase Credentials (NEVER commit these) ---
serviceAccountKey.json
calendar_credentials.json
*serviceAccount*.json
*.json.key
firebase-adminsdk*.json

# --- Local mock database (runtime artifact) ---
backend/mock_db.json
backend/mock_storage/

# --- Node.js ---
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# --- Build outputs ---
frontend/dist/
dist/

# --- IDE & OS ---
.vscode/
.idea/
.gemini/
Thumbs.db
.DS_Store
*.log
*.swp
*.swo

# --- Celery & Redis ---
celerybeat-schedule
celerybeat.pid

# --- Test data ---
test_cv.pdf
resumes/
